{
"family": "strapi-task-libin",
"executionRoleArn": "arn:aws:iam::811738710312:role:role/ecsTaskExecutionRole",
"networkMode": "awsvpc",
"requiresCompatibilities": ["FARGATE"],
"cpu": "256",
"memory": "512",

"containerDefinitions": [
{
"name": "strapi",
"image": "IMAGE_URI",
"essential": true,


  "portMappings": [
    {
      "containerPort": 1337,
      "hostPort": 1337,
      "protocol": "tcp"
    }
  ],

  "environment": [
    {
      "name": "HOST",
      "value": "0.0.0.0"
    }
  ]
}


]
}
